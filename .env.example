# Tea Garden Scraper Environment Variables

# Google Maps API Key (required for --mode=maps)
# Get one from: https://developers.google.com/maps/documentation/places/web-service/get-api-key
GOOGLE_MAPS_API_KEY=your_api_key_here

# Optional: Browser settings for visual verification
# HEADLESS=true  # Run browser in headless mode (default: true)
